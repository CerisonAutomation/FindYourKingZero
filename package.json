    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:seed": "tsx scripts/seed.ts",
    "deploy:staging": "vercel --env staging",
    "deploy:prod": "vercel --env production",
    "postbuild": "npm run test:e2e && npm run test:coverage"
