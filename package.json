{
  "name": "findyourking",
  "version": "4.0.0",
  "description": "Modern dating platform for the LGBTQ+ community with privacy-first architecture",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --port 5000 --host 0.0.0.0",
    "build": "vite build --mode production",
    "build:analyze": "vite build && npx vite-bundle-analyzer dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings 50",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "supabase gen types typescript --local > src/integrations/supabase/types.ts",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:seed": "tsx scripts/seed.ts",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "performance:analyze": "npm run build && npm run build:analyze",
    "ci:all": "npm run type-check && npm run lint && npm run test && npm run security:audit",
    "deploy:vercel": "vercel --prod",
    "deploy:capacitor": "npm run build && npx cap sync && npx cap run android",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:android": "npx cap run android",
    "mobile:ios": "npx cap run ios"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@assistant-ui/react": "^0.12.19",
    "@assistant-ui/react-ai-sdk": "^1.3.14",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@hookform/resolvers": "^3.10.0",
    "@huggingface/transformers": "^3.8.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@sentry/react": "^8.0.0",
    "@supabase/auth-js": "^2.99.3",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.83.0",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^4.7.0",
    "ai": "^4.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "maplibre-gl": "^4.7.1",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "trystero": "^0.22.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@vitest/ui": "^3.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "postcss": "^8.5.8",
    "prettier": "^3.1.0",
    "puppeteer": "^24.40.0",
    "terser": "^5.46.1",
    "tsx": "^4.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vercel": "^37.4.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "npm@10.9.2"
}
