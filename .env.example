# =============================================================================
# FindYourKingZero — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit real secrets to source control.
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults documented inline.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
VITE_APP_NAME=FindYourKing
VITE_APP_VERSION=4.0.0
VITE_APP_URL=http://localhost:5000
VITE_APP_ENV=development               # development | staging | production
VITE_DEBUG=false
VITE_MAINTENANCE=false

# =============================================================================
# SUPABASE [REQUIRED]
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: server-side only, never expose in browser
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase feature flags
VITE_SUPABASE_ENABLE_REALTIME=true
VITE_SUPABASE_ENABLE_POSTGIS=true

# Connection pool (Supabase edge functions / server only)
VITE_SUPABASE_POOL_MIN=2
VITE_SUPABASE_POOL_MAX=10
VITE_SUPABASE_POOL_IDLE_TIMEOUT=30000

# =============================================================================
# AUTHENTICATION
# =============================================================================
VITE_AUTH_DEBUG=false
# Callback URLs (must match Supabase Auth redirect allow-list)
VITE_AUTH_CALLBACK_URL=http://localhost:5000/auth/callback
VITE_MAGIC_LINK_CALLBACK_URL=http://localhost:5000/auth/callback

# =============================================================================
# API
# =============================================================================
VITE_API_URL=http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# =============================================================================
# AI / LLM
# =============================================================================
# OpenAI (optional — enables cloud AI matching & coaching)
VITE_OPENAI_API_KEY=sk-...

# OpenRouter (alternative multi-model gateway)
VITE_OPENROUTER_API_KEY=sk-or-...

# AI model settings
VITE_AI_PROVIDER=openai                # openai | openrouter | local
VITE_AI_MODEL=gpt-4o-mini
VITE_AI_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=1024
VITE_AI_TIMEOUT=30000
VITE_AI_RATE_LIMIT_RPM=60
VITE_AI_RATE_LIMIT_TPM=40000
VITE_AI_ENABLE_STREAMING=true
VITE_AI_ENABLE_MODERATION=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_AI=true
VITE_ENABLE_AI_MATCHING=true
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_AI_QUICK_REPLIES=true
VITE_ENABLE_AI_STREAMING=true
VITE_ENABLE_AI_MODERATION=true
VITE_ENABLE_AI_ANALYSIS=false
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_MULTI_LANGUAGE=false
VITE_ENABLE_BETA_FEATURES=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_PERFORMANCE_MONITORING=false
VITE_ENABLE_MONITORING=false
VITE_ENABLE_REMOTE_CONFIG=false
VITE_ENABLE_RUM=false
VITE_ENABLE_WEB_VITALS=true
VITE_ENABLE_GEOHASH=true

# Feature flags (granular)
VITE_FEATURE_AI=true
VITE_FEATURE_AI_MATCHING=true
VITE_FEATURE_P2P=true
VITE_FEATURE_REALTIME=true
VITE_FEATURE_STRIPE=false
VITE_FEATURE_CALLS=false
VITE_FEATURE_VIDEO_CALLS=false
VITE_FEATURE_VOICE_CONTROL=false
VITE_FEATURE_PWA=true
VITE_FEATURE_EVENTS_SYSTEM=true
VITE_FEATURE_ADVANCED_FILTERS=true
VITE_FEATURE_METRICS=false
VITE_FEATURE_AR_DATING=false
VITE_FEATURE_BLOCKCHAIN_REWARDS=false
VITE_ENABLE_P2P=true

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# Sentry (error monitoring)
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Google Analytics
VITE_ANALYTICS_ID=GA-XXXXXXXXX
VITE_ANALYTICS_TRACKING_ID=G-XXXXXXXXXX
VITE_ANALYTICS_PROVIDER=none           # none | google | plausible | posthog
VITE_ANALYTICS_ENABLE_TRACKING=false
VITE_ANALYTICS_ENABLE_USER_TRACKING=false
VITE_ANALYTICS_ENABLE_PERFORMANCE_TRACKING=false
VITE_ANALYTICS_ENABLE_ERROR_TRACKING=false
VITE_ANALYTICS_DATA_RETENTION=90       # days

# Error tracking
VITE_ERROR_TRACKING_PROVIDER=none      # none | sentry | bugsnag
VITE_ERROR_TRACKING_DSN=

# Performance
VITE_PERFORMANCE_ENABLE_METRICS=false
VITE_PERFORMANCE_ENABLE_PROFILING=false
VITE_PERFORMANCE_ENABLE_TRACING=false
VITE_PERFORMANCE_SAMPLE_RATE=0.1
VITE_PERFORMANCE_ALERT_RESPONSE_TIME=3000
VITE_PERFORMANCE_ALERT_ERROR_RATE=0.05
VITE_PERFORMANCE_ALERT_MEMORY_USAGE=0.85

# Log endpoint (optional remote logging)
VITE_LOG_ENDPOINT=

# =============================================================================
# MAPS
# =============================================================================
VITE_MAPS_PROVIDER=maplibre            # maplibre | leaflet
VITE_MAPS_API_KEY=                     # Only required for Google Maps / Mapbox
VITE_MAPS_DEFAULT_ZOOM=13
VITE_MAPS_MAX_ZOOM=18
VITE_MAPS_ENABLE_GEOLOCATION=true
VITE_MAPS_ENABLE_CLUSTERING=true
VITE_MAPS_PRIVACY_RADIUS=200           # metres to fuzz user location on map
VITE_MAPS_UPDATE_INTERVAL=30000        # ms

# =============================================================================
# LOCATION & PRIVACY
# =============================================================================
VITE_GEOHASH_PRECISION=6
VITE_LOCATION_PRIVACY_RADIUS=200

# =============================================================================
# REALTIME
# =============================================================================
VITE_REALTIME_RECONNECT_INTERVAL=5000
VITE_REALTIME_MAX_RECONNECTS=10

# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_VAPID_KEY=your_vapid_key

# =============================================================================
# CDN
# =============================================================================
VITE_CDN_ENABLED=false
VITE_CDN_URL=https://cdn.example.com
VITE_CDN_PROVIDER=cloudflare           # cloudflare | cloudfront | none
VITE_CDN_ENABLE_CACHING=true
VITE_CDN_ENABLE_COMPRESSION=true
VITE_CDN_CACHE_TTL=86400

# =============================================================================
# SECURITY
# =============================================================================
VITE_SECURITY_ENABLE_CSP=true
VITE_SECURITY_ENABLE_RATE_LIMIT=true
VITE_SECURITY_ENABLE_XSS_PROTECTION=true
VITE_SECURITY_SESSION_TIMEOUT=3600     # seconds
VITE_SECURITY_MAX_LOGIN_ATTEMPTS=5
VITE_SECURITY_LOCKOUT_DURATION=900     # seconds
VITE_SECURITY_KEY_ROTATION=false

# =============================================================================
# MOBILE (Capacitor)
# =============================================================================
VITE_MOBILE_ENABLE_PUSH=true
VITE_MOBILE_ENABLE_BIOMETRIC=false
VITE_MOBILE_ENABLE_OFFLINE=true
VITE_MOBILE_SYNC_INTERVAL=30000
VITE_MOBILE_MAX_CACHE_SIZE=100         # MB
