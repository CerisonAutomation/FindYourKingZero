# Environment variables for development
# Copy this to .env.local and configure with your actual values

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# =====================================================
# AUTHENTICATION CONFIGURATION
# =====================================================
VITE_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
VITE_MAGIC_LINK_CALLBACK_URL=http://localhost:3000/auth/callback

# =====================================================
# API CONFIGURATION
# =====================================================
VITE_API_URL=http://localhost:3000/api
VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_WEBSOCKET_URL=ws://localhost:5000

# =====================================================
# STRIPE CONFIGURATION
# =====================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# =====================================================
# ANALYTICS CONFIGURATION
# =====================================================
VITE_SENTRY_DSN=your_sentry_dsn
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =====================================================
# FEATURE FLAGS
# =====================================================
VITE_ENABLE_AI_MATCHING=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_STORYBOOK=true

# =====================================================
# DEVELOPMENT CONFIGURATION
# =====================================================
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug
VITE_MOCK_API=false
