# =====================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.production and fill in values
# NEVER commit .env.production to version control
# =====================================================

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App metadata
VITE_APP_NAME=FindYourKing
VITE_APP_VERSION=4.0.0
VITE_APP_ENV=production
VITE_APP_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com/api

# Maps
VITE_MAPS_PROVIDER=maplibre

# Feature flags
VITE_ENABLE_PWA=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_AI=true

# Optional — Sentry error tracking
# VITE_SENTRY_DSN=

# Optional — Google Analytics
# VITE_GA_ID=

# Optional — Stripe (publishable key only — safe for client)
# VITE_STRIPE_PUBLISHABLE_KEY=

# Optional — Google Maps (restrict by domain in Google Cloud Console)
# VITE_GOOGLE_MAPS_API_KEY=

# Optional — OpenAI (only if using client-side AI features — prefer server-side)
# VITE_OPENAI_API_KEY=

# Optional — OAuth client IDs (public by design)
# VITE_FACEBOOK_APP_ID=
# VITE_GOOGLE_CLIENT_ID=
