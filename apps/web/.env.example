# ═══════════════════════════════════════════════════════════════
# FindYourKingZero — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Supabase (Auth) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── API Backend ──────────────────────────────────────────────
# Leave empty to use Vercel serverless API (api/index.ts)
# Set to your Hono server URL if running apps/server separately
VITE_API_URL=

# ── App ──────────────────────────────────────────────────────
VITE_APP_VERSION=5.1.0

# ── Server (apps/server only) ────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/findyourking
JWT_SECRET=change-this-to-a-random-secret
PORT=3000
