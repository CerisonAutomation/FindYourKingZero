# Production environment variables
# Configure with your actual production values

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key

# =====================================================
# AUTHENTICATION CONFIGURATION
# =====================================================
VITE_AUTH_CALLBACK_URL=https://your-domain.com/auth/callback
VITE_MAGIC_LINK_CALLBACK_URL=https://your-domain.com/auth/callback

# =====================================================
# API CONFIGURATION
# =====================================================
VITE_API_URL=https://api.your-domain.com
VITE_GRAPHQL_URL=https://api.your-domain.com/graphql
VITE_WEBSOCKET_URL=wss://ws.your-domain.com

# =====================================================
# STRIPE CONFIGURATION
# =====================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key

# =====================================================
# ANALYTICS CONFIGURATION
# =====================================================
VITE_SENTRY_DSN=your_production_sentry_dsn
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =====================================================
# FEATURE FLAGS
# =====================================================
VITE_ENABLE_AI_MATCHING=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_STORYBOOK=false

# =====================================================
# PRODUCTION CONFIGURATION
# =====================================================
VITE_DEV_MODE=false
VITE_LOG_LEVEL=error
VITE_MOCK_API=false
